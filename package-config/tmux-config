# --- Mouse: click to focus/select panes, drag borders to resize,
#     drag-select text and it copies automatically (zellij-style) ---
set -g mouse on
set -g set-clipboard on

# --- The whole reason we're doing this: let VSCode's shell integration
#     escape codes reach the outer terminal ---
set -g allow-passthrough on
set -ga update-environment TERM_PROGRAM
set -ga update-environment TERM_PROGRAM_VERSION

set -g default-terminal "tmux-256color"
set-option -sa terminal-overrides ",xterm*:Tc"

# --- Sensible, no-prefix-needed navigation (like zellij's Alt+arrows) ---
bind -n M-Left  select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up    select-pane -U
bind -n M-Down  select-pane -D
bind -n M-h     split-window -h -c "#{pane_current_path}"
bind -n M-v     split-window -v -c "#{pane_current_path}"
bind -n M-w     kill-pane
bind -n M-n     new-window -c "#{pane_current_path}"

# --- Reload config quickly, like zellij's live-reload feel ---
unbind r
bind r source-file ~/.config/tmux/tmux.conf \; display-message "reloaded"


# ============================================================
# Zellij-style modal keybindings for tmux
# ============================================================

# --- Enter each mode with the same keys zellij uses, no prefix ---
bind -n C-p switch-client -T pane      # Pane mode
bind -n C-t switch-client -T tab       # Tab mode
bind -n C-n switch-client -T resize    # Resize mode
bind -n C-h switch-client -T move      # Move mode
bind -n C-o switch-client -T session   # Session mode
bind -n C-s copy-mode \; switch-client -T scroll  # Scroll mode
bind -n C-q confirm-before -p "quit tmux? (y/n)" kill-server

# --- PANE mode (Ctrl+p, then:) ---
bind -T pane n split-window -v -c "#{pane_current_path}" \; switch-client -T root   # new pane below
bind -T pane r split-window -h -c "#{pane_current_path}" \; switch-client -T root   # new pane right
bind -T pane x kill-pane \; switch-client -T root                                    # close pane
bind -T pane f resize-pane -Z \; switch-client -T root                               # toggle fullscreen/zoom
bind -T pane h select-pane -L \; switch-client -T pane
bind -T pane j select-pane -D \; switch-client -T pane
bind -T pane k select-pane -U \; switch-client -T pane
bind -T pane l select-pane -R \; switch-client -T pane
bind -T pane Left  select-pane -L \; switch-client -T pane
bind -T pane Down  select-pane -D \; switch-client -T pane
bind -T pane Up    select-pane -U \; switch-client -T pane
bind -T pane Right select-pane -R \; switch-client -T pane
bind -T pane p select-pane -t :.+ \; switch-client -T pane   # cycle focus
bind -T pane Escape switch-client -T root
bind -T pane Enter  switch-client -T root

# --- TAB mode (Ctrl+t, then:) --- tmux "windows" = zellij "tabs"
bind -T tab n new-window -c "#{pane_current_path}" \; switch-client -T root
bind -T tab x kill-window \; switch-client -T root
bind -T tab r command-prompt -I "#W" "rename-window '%%'" \; switch-client -T root
bind -T tab h previous-window \; switch-client -T tab
bind -T tab l next-window \; switch-client -T tab
bind -T tab Left  previous-window \; switch-client -T tab
bind -T tab Right next-window \; switch-client -T tab
bind -T tab Tab last-window \; switch-client -T root
bind -T tab 1 select-window -t :1 \; switch-client -T root
bind -T tab 2 select-window -t :2 \; switch-client -T root
bind -T tab 3 select-window -t :3 \; switch-client -T root
bind -T tab 4 select-window -t :4 \; switch-client -T root
bind -T tab 5 select-window -t :5 \; switch-client -T root
bind -T tab Escape switch-client -T root
bind -T tab Enter  switch-client -T root

# --- RESIZE mode (Ctrl+n, then:) ---
bind -T resize h resize-pane -L 5 \; switch-client -T resize
bind -T resize j resize-pane -D 5 \; switch-client -T resize
bind -T resize k resize-pane -U 5 \; switch-client -T resize
bind -T resize l resize-pane -R 5 \; switch-client -T resize
bind -T resize Left  resize-pane -L 5 \; switch-client -T resize
bind -T resize Down  resize-pane -D 5 \; switch-client -T resize
bind -T resize Up    resize-pane -U 5 \; switch-client -T resize
bind -T resize Right resize-pane -R 5 \; switch-client -T resize
bind -T resize = select-layout tiled \; switch-client -T root
bind -T resize Escape switch-client -T root
bind -T resize Enter  switch-client -T root

# --- MOVE mode (Ctrl+h, then:) --- swap pane position
bind -T move h swap-pane -s '{left-of}'  \; switch-client -T move
bind -T move j swap-pane -s '{down-of}'  \; switch-client -T move
bind -T move k swap-pane -s '{up-of}'    \; switch-client -T move
bind -T move l swap-pane -s '{right-of}' \; switch-client -T move
bind -T move Escape switch-client -T root
bind -T move Enter  switch-client -T root

# --- SESSION mode (Ctrl+o, then:) ---
bind -T session d detach-client \; switch-client -T root
bind -T session w choose-tree -Zs \; switch-client -T root
bind -T session r command-prompt -I "#S" "rename-session '%%'" \; switch-client -T root
bind -T session Escape switch-client -T root
bind -T session Enter  switch-client -T root

# --- SCROLL mode (Ctrl+s enters copy-mode automatically) ---
bind -T scroll j send-keys -X cursor-down \; switch-client -T scroll
bind -T scroll k send-keys -X cursor-up \; switch-client -T scroll
bind -T scroll Escape send-keys -X cancel \; switch-client -T root
bind -T scroll Enter  send-keys -X cancel \; switch-client -T root
